# 混合联调环境变量（IDE Run Configuration / 复制为 .env.integration）
MIS_REMOTE=true
NACOS_SERVER=localhost:8848
NACOS_NAMESPACE=integration
# 容器内 Gateway 访问宿主机 IDE 实例（Windows/macOS Docker Desktop）
NACOS_REGISTER_IP=host.docker.internal

DB_HOST=localhost
DB_PORT=5432
DB_NAME=mis_platform
DB_USER=mis
DB_PASSWORD=mis123

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_PRIVATE_KEY_PATH=./backend/keys/private.pem
JWT_PUBLIC_KEY_PATH=./backend/keys/public.pem

AUTH_CAPTCHA_ENABLED=false

# 运行集成测试
# MIS_INTEGRATION_TEST=true
# MIS_GATEWAY_URL=http://localhost:8080
