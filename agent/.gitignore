# =============================================================================
# ai-platform-workbuddy — Git 忽略规则
# =============================================================================

# ----- 操作系统 -----
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ----- IDE / 编辑器 -----
.idea/
*.iml
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~

# ----- 环境变量与密钥（保留 .env.example） -----
.env
.env.local
.env.*.local
!.env.example

# ----- Python / Backend -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.eggs/
dist/
build/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
pip-log.txt
pip-delete-this-directory.txt

# Backend 运行日志（logs/.gitignore 已忽略内容，此处兜底）
ai-platform/backend/logs/*.log
ai-platform/backend/logs/*.log.*

# ----- Node.js / Frontend & Gateway -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# 构建产物
dist/
dist-ssr/
build/
*.local

# Vite / 前端缓存
.vite/
*.tsbuildinfo

# ----- Docker / 本地数据卷 -----
*.log
docker-data/
infra/data/
redis-data/
postgres-data/
qdrant-data/

# ----- 测试与临时文件 -----
coverage/
.nyc_output/
*.tmp
*.temp
.cache/

# ----- 打包与部署产物 -----
*.tar
*.tar.gz
*.zip
*.whl
