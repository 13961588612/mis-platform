# =============================================================================
# Backend Environment Variables — Example Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# In production, use Docker environment variables or a secrets manager.
# =============================================================================

# ===== Application =====
APP_NAME=ai-platform-backend
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE=logs/backend.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ===== Server =====
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ===== PostgreSQL =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aiplatform
POSTGRES_PASSWORD=aiplatform_dev_password
POSTGRES_DB=ai_platform

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=2
REDIS_PASSWORD=

# ===== Qdrant =====
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# ===== Embedding Model =====
EMBEDDING_SERVICE_URL=http://embedding:8001
EMBEDDING_MODEL_NAME=bge-small-zh-v1.5
EMBEDDING_DIMENSION=768

# ===== LLM Gateway — DeepSeek =====
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_ENDPOINT=https://api.deepseek.com/v1

# ===== LLM Gateway — Qwen =====
QWEN_API_KEY=your-qwen-api-key-here
QWEN_API_ENDPOINT=https://dashscope.aliyuncs.com/api/v1

# ===== Outbound Proxy =====
OUTBOUND_PROXY_ENABLED=true
OUTBOUND_PROXY_HOST=outbound-proxy
OUTBOUND_PROXY_PORT=3128

# ===== JWT / Authentication =====
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Dev Test Accounts =====
DEV_TEST_ACCOUNTS_ENABLED=true
TEST_ACCOUNTS_FILE=test-accounts.yaml

STREAM_CONSUMER_ENABLED=true
STREAM_CONSUMER_GROUP=agent-core-group
# 入站消费并发：进程内同时处理上限；每次 XREADGROUP 条数
INBOUND_MAX_CONCURRENCY=8
INBOUND_READ_COUNT=1
# Agent 单条消息处理超时（秒）；MCP 单次工具调用超时（秒）
AGENT_MESSAGE_TIMEOUT=120
MCP_TOOL_CALL_TIMEOUT=30

# ===== Enterprise WeChat =====
WECOM_CORP_ID=your-corp-id
WECOM_AGENT_ID=your-agent-id
WECOM_SECRET=your-secret
WECOM_ENCODING_AES_KEY=your-encoding-aes-key
WECOM_TOKEN=your-callback-token
WECOM_BOT_CALLBACK_TOKEN=your-bot-callback-token
WECOM_BOT_CALLBACK_ENCODING_AES_KEY=your-bot-aes-key

# ===== Credential Vault (AES-256-GCM, 32 bytes) =====
CREDENTIAL_VAULT_KEY=change-this-to-32-byte-secure-key!

# ===== Config Manager =====
CONFIG_MODE=file_system
CONFIG_BASE_PATH=/app/configs
CONFIG_WATCH_ENABLED=true

# ===== Agent Router =====
AGENT_ROUTER_DEFAULT_AGENT=default-agent
