# 本地开发环境变量（复制为 .env 后按需修改）
# cp .env.example .env

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mis_platform
DB_USER=mis
DB_PASSWORD=mis123

# JDK 17（Maven 父 POM 引用 ${env.JAVA_HOME_17}）
JAVA_HOME_17=C:/Program Files/Eclipse Adoptium/jdk-17.0.11.9-hotspot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Nacos（配置中心 Server；微服务默认不连，见 docs/devops/configuration.md）
NACOS_SERVER=localhost:8848
NACOS_NAMESPACE=dev
NACOS_CONFIG_ENABLED=false
NACOS_CONFIG_GROUP=MIS_GROUP
NACOS_DISCOVERY_ENABLED=false

# 外部文件配置目录（test/prod profile）
# MIS_CONFIG_HOME=./deploy/config/test

# JWT（开发用，生产走 Nacos/Vault）
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
